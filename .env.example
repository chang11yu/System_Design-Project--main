# Local default is SQLite, so DATABASE_URL can be omitted locally.
# For Render, paste a Neon pooled PostgreSQL connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Comma-separated allowed website origins.
# Example GitHub Pages origin:
CORS_ORIGINS=https://YOUR_GITHUB_NAME.github.io

SECRET_KEY=replace-with-a-random-secret
